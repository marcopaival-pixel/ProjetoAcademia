{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/_envelope.json",
  "title": "FabricaAgentArtifact",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "agent",
    "artifact_type",
    "created_at",
    "depends_on",
    "assumptions",
    "open_questions",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "minLength": 4 },
    "agent": { "type": "string", "minLength": 2 },
    "artifact_type": { "type": "string", "minLength": 2 },
    "version": {
      "type": "string",
      "description": "Optional revision of this artifact (e.g. semver or draft label). Distinct from schema_version."
    },
    "created_at": { "type": "string", "format": "date-time" },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Paths or logical refs to prior artifacts"
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
