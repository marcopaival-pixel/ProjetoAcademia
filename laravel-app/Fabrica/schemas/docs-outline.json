{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/docs-outline.json",
  "title": "DocsOutlinePayload",
  "type": "object",
  "required": ["audiences", "documents", "diagrams"],
  "properties": {
    "audiences": { "type": "array", "items": { "type": "string" } },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "outline", "owner"],
        "properties": {
          "title": { "type": "string" },
          "outline": { "type": "array", "items": { "type": "string" } },
          "owner": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["draft", "maintained", "deprecated"],
            "description": "Lifecycle of this document; align with master-plan artifact_index.status when useful."
          }
        },
        "additionalProperties": false
      }
    },
    "diagrams": { "type": "array", "items": { "type": "string" } },
    "glossary": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
