{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/release-checklist.json",
  "title": "ReleaseChecklistPayload",
  "type": "object",
  "required": ["version", "items", "signoff"],
  "properties": {
    "version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "done"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "done": { "type": "boolean" },
          "owner": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "signoff": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "status"],
        "properties": {
          "role": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
