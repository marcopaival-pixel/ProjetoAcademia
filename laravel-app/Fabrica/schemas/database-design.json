{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/database-design.json",
  "title": "DatabaseDesignPayload",
  "type": "object",
  "required": ["engine", "schemas", "migration_strategy", "indexing", "data_retention"],
  "properties": {
    "engine": { "type": "string" },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tables"],
        "properties": {
          "name": { "type": "string" },
          "tables": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "columns"],
              "properties": {
                "name": { "type": "string" },
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" },
                      "nullable": { "type": "boolean" },
                      "pk": { "type": "boolean" },
                      "fk": { "type": "string" },
                      "unique": { "type": "boolean" },
                      "default": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                },
                "indexes": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "migration_strategy": { "type": "string" },
    "indexing": { "type": "array", "items": { "type": "string" } },
    "data_retention": { "type": "string" }
  },
  "additionalProperties": false
}
