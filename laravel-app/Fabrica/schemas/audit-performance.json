{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/audit-performance.json",
  "title": "AuditPerformancePayload",
  "type": "object",
  "required": ["summary", "findings"],
  "properties": {
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "title", "summary", "recommendation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["critical", "medium", "low"]
          },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "recommendation": { "type": "string" },
          "production_safety": {
            "type": "string",
            "enum": ["safe-incremental", "needs-flag", "high-risk"]
          }
        },
        "additionalProperties": false
      }
    },
    "bottlenecks": { "type": "array", "items": { "type": "string" } },
    "slow_queries_or_io": { "type": "array", "items": { "type": "string" } },
    "unnecessary_calls": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
