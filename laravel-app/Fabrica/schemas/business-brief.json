{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/business-brief.json",
  "title": "BusinessBriefPayload",
  "type": "object",
  "required": [
    "vision",
    "target_users",
    "value_proposition",
    "business_model",
    "kpis",
    "constraints"
  ],
  "properties": {
    "vision": { "type": "string" },
    "target_users": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment", "needs"],
        "properties": {
          "segment": { "type": "string" },
          "needs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "value_proposition": { "type": "string" },
    "business_model": {
      "type": "object",
      "required": ["pricing_hypothesis", "monetization"],
      "properties": {
        "pricing_hypothesis": { "type": "string" },
        "monetization": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "kpis": { "type": "array", "items": { "type": "string" } },
    "constraints": {
      "type": "object",
      "properties": {
        "regulatory": { "type": "array", "items": { "type": "string" } },
        "timeline": { "type": "string" },
        "budget": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
