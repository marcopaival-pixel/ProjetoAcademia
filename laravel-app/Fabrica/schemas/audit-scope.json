{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/audit-scope.json",
  "title": "AuditScopePayload",
  "type": "object",
  "required": [
    "target_summary",
    "audit_goals",
    "constraints",
    "scope_in",
    "scope_out"
  ],
  "properties": {
    "target_summary": {
      "type": "string",
      "description": "Visão do sistema-alvo (produto, repos, ambientes)."
    },
    "repo_roots": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Caminhos ou URLs dos repositórios auditados."
    },
    "builder_run_id": {
      "type": "string",
      "description": "Opcional: run_id do System Builder que originou o sistema."
    },
    "audit_goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ex.: não quebrar produção, janela de mudança, compliance."
    },
    "scope_in": { "type": "array", "items": { "type": "string" } },
    "scope_out": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
