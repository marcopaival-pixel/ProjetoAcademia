{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/evolution-run-report.json",
  "title": "EvolutionRunReportPayload",
  "type": "object",
  "required": [
    "run_summary",
    "pull_requests",
    "verification_checklist",
    "rollback_notes",
    "follow_up"
  ],
  "properties": {
    "run_summary": { "type": "string" },
    "pull_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "branch",
          "title",
          "description",
          "risk_level",
          "merge_recommendation"
        ],
        "properties": {
          "branch": { "type": "string" },
          "title": { "type": "string" },
          "description": {
            "type": "string",
            "description": "Corpo do PR ou resumo com contexto, motivação e riscos."
          },
          "url": { "type": "string" },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "merge_recommendation": {
            "type": "string",
            "enum": ["merge-after-ci", "needs-human-review", "do-not-merge"]
          },
          "source_agents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "files_changed": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "verification_checklist": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rollback_notes": { "type": "array", "items": { "type": "string" } },
    "follow_up": { "type": "array", "items": { "type": "string" } },
    "factory_integration": {
      "type": "object",
      "description": "Laços com Audit (reauditar) e Builder (atualizar specs).",
      "required": ["suggested_next_actions"],
      "properties": {
        "related_audit_run_id": { "type": "string" },
        "related_builder_run_id": { "type": "string" },
        "suggested_next_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
