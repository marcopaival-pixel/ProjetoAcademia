{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/code-review-report.json",
  "title": "CodeReviewReportPayload",
  "type": "object",
  "required": ["scope", "summary", "findings", "merge_recommendation"],
  "properties": {
    "scope": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "location", "issue", "fix"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocker", "major", "minor", "nitro"]
          },
          "location": { "type": "string" },
          "issue": { "type": "string" },
          "fix": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "merge_recommendation": {
      "type": "string",
      "enum": ["approve", "approve_with_comments", "request_changes"]
    }
  },
  "additionalProperties": false
}
