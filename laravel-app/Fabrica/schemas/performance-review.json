{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/performance-review.json",
  "title": "PerformanceReviewPayload",
  "type": "object",
  "required": ["goals", "benchmarks", "hotspots", "recommendations"],
  "properties": {
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric", "target"],
        "properties": {
          "metric": { "type": "string" },
          "target": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "benchmarks": { "type": "array", "items": { "type": "string" } },
    "hotspots": { "type": "array", "items": { "type": "string" } },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "impact", "effort"],
        "properties": {
          "item": { "type": "string" },
          "impact": { "type": "string" },
          "effort": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
