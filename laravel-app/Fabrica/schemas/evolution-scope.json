{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/evolution-scope.json",
  "title": "EvolutionScopePayload",
  "type": "object",
  "required": [
    "target_summary",
    "repository",
    "goals",
    "constraints",
    "safety_policy",
    "automation_mode"
  ],
  "properties": {
    "target_summary": {
      "type": "string",
      "description": "Contexto do sistema e do que se deseja evoluir."
    },
    "repository": {
      "type": "object",
      "required": ["default_branch"],
      "properties": {
        "remote_url": { "type": "string" },
        "local_path": { "type": "string" },
        "default_branch": { "type": "string" },
        "work_branch_prefix": {
          "type": "string",
          "description": "Ex.: fabrica-evol/"
        }
      },
      "additionalProperties": false
    },
    "goals": { "type": "array", "items": { "type": "string" } },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Regras de negócio, janelas, compliance, stack fixa, etc."
    },
    "depends_on_audit": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Caminhos para `99-audit-consolidated-report.json` ou especialistas."
    },
    "safety_policy": {
      "type": "object",
      "required": ["require_review_for_risk"],
      "properties": {
        "require_review_for_risk": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "description": "Níveis de risco que exigem revisão humana explícita antes de merge."
        },
        "max_files_per_pr": { "type": "integer", "minimum": 1 },
        "forbidden_path_globs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_checks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ex.: npm test, lint, typecheck, policy-as-code."
        }
      },
      "additionalProperties": false
    },
    "automation_mode": {
      "type": "string",
      "enum": ["suggest-only", "pr-low-risk-only", "pr-tiered-gates"],
      "description": "`suggest-only` não abre PR; `pr-low-risk-only` automa PR só para risco baixo; `pr-tiered-gates` permite vários PRs com política em safety_policy."
    }
  },
  "additionalProperties": false
}
