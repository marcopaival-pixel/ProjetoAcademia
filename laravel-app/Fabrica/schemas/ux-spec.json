{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/ux-spec.json",
  "title": "UxSpecPayload",
  "type": "object",
  "required": ["information_architecture", "key_flows", "components", "accessibility"],
  "properties": {
    "design_principles": { "type": "array", "items": { "type": "string" } },
    "information_architecture": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["area", "screens"],
        "properties": {
          "area": { "type": "string" },
          "screens": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "key_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "steps"],
        "properties": {
          "name": { "type": "string" },
          "steps": { "type": "array", "items": { "type": "string" } },
          "edge_cases": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "states": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "accessibility": {
      "type": "object",
      "required": ["wcag_target", "notes"],
      "properties": {
        "wcag_target": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
