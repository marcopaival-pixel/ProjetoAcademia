{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fabrica.local/schemas/frontend-spec.json",
  "title": "FrontendSpecPayload",
  "type": "object",
  "required": ["stack", "routing", "state", "modules", "api_client"],
  "properties": {
    "stack": {
      "type": "object",
      "required": ["framework", "language"],
      "properties": {
        "framework": { "type": "string" },
        "language": { "type": "string" },
        "ui_library": { "type": "string" },
        "styling": { "type": "string" }
      },
      "additionalProperties": true
    },
    "routing": { "type": "array", "items": { "type": "string" } },
    "state": { "type": "string" },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "scope"],
        "properties": {
          "name": { "type": "string" },
          "scope": { "type": "string" },
          "depends_on_backend": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "api_client": {
      "type": "object",
      "required": ["codegen", "error_handling"],
      "properties": {
        "codegen": { "type": "boolean" },
        "error_handling": { "type": "string" }
      },
      "additionalProperties": true
    },
    "performance_budgets": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
