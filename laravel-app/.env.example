APP_NAME=ProjetoAcademia
APP_ENV=local
APP_KEY=
APP_VERSION=1.1.0-rc1
APP_DEBUG=true
# Com `php artisan serve` use o mesmo host/porta (ex.: http://localhost:8000). Com Apache numa subpasta, use essa URL completa até /public.
APP_URL=http://localhost:8000
SYSTEM_LOGIN_URL=https://app.nexshape.com.br/login
# Obrigatório para Mercado Pago (igual ao php-app): URL pública até a pasta public.
APP_PUBLIC_URL=
# Se o app estiver em subpasta (ex.: /academia/public), defina aqui sem barras extras.
APP_BASE_PATH=
APP_TIMEZONE=America/Sao_Paulo

# Opcional: e-mail de um utilizador já existente que passa a administrador ao correr php artisan db:seed (is_admin=1).
ADMIN_EMAIL=
# E-mail operacional usado para alertas críticos mesmo quando a base de dados está indisponível.
OPERATIONAL_ALERT_EMAIL=
LGPD_DPO_EMAIL=

MP_ACCESS_TOKEN=

# Chave secreta para validação HMAC-SHA256 dos webhooks do Mercado Pago.
# Obter em: Conta MP > Webhooks > Chave secreta.
# OBRIGATÓRIO em produção — webhooks MP retornam 503 se vazio com APP_ENV=production.
MP_WEBHOOK_SECRET=

# Open Food Facts (API pública; opcional — URL base do servidor)
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org
# Limite por utilizador (pesquisas + fichas de produto por minuto)
OPENFOODFACTS_MAX_REQUESTS_PER_MINUTE=30
# Cache local de fichas de produto (segundos); 0 desativa
OPENFOODFACTS_CACHE_PRODUCT_TTL=3600
# Pesquisa por nome (segundos); 0 desliga
OPENFOODFACTS_CACHE_SEARCH_TTL=600

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# XAMPP / MySQL local: 127.0.0.1. Em Docker Compose costuma ser o serviço "mysql".
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=projetoacademia
DB_USERNAME=root
DB_PASSWORD=

# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# Sem Redis local: use "database" (tabela sessions) ou "file".
# PRODUÇÃO (recomendado): Redis para SESSION_DRIVER, CACHE_STORE e QUEUE_CONNECTION — ver docs/DEPLOY_NEXSHAPE.md e docs/supervisor-nexshape.conf.example
SESSION_DRIVER=database
SESSION_COOKIE=projetoacademia_sid
SESSION_LIFETIME=120
# PRODUÇÃO (HTTPS obrigatório): SESSION_ENCRYPT=true e SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# Retenção de logs (dias) — ver config/observability.php e comando app:purge-old-logs
# LOG_RETENTION_FINANCIAL_DAYS=365
# LOG_RETENTION_AUTH_DAYS=90
# LOG_RETENTION_REP_AUDIT_DAYS=365

# Escrita legada mercadopago_payment_credits (manter false em produção)
# LEGACY_MP_CREDITS_WRITE=false

# Importar histórico legado MP para payments (uma vez, em manutenção):
# php artisan finance:backfill-legacy-mp --dry-run
# php artisan finance:backfill-legacy-mp

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# sync = dev simples; database = sem Redis; redis = produção com Supervisor (queue:work)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Com CACHE/SESSION/QUEUE em redis, em Docker use o hostname do serviço (ex.: redis).
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cópias opcionais em envios transacionais (TransactionalMailService): administrador, financeiro, suporte; BCC separado por vírgulas
MAIL_COPY_ADMIN=
MAIL_COPY_FINANCE=
MAIL_COPY_SUPPORT=
MAIL_COPY_BCC=
# Janela em segundos para bloquear reenvio duplicado (mesmo utilizador, tipo e assunto de log)
MAIL_DEDUPE_SECONDS=60

# Confirmação de e-mail (auto cadastro): expiração do link (horas) e máx. envios por hora por utilizador
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_VERIFICATION_MAX_SENDS_PER_HOUR=3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# API v1 (Sanctum) — tokens para integrações; ver docs/API_V1.md
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# API v1 (Sanctum) — tokens para integrações móveis/terceiros; ver laravel-app/docs/API_V1.md
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# --- OpenAI (chat nutricional) ---
# Nunca commite o ficheiro .env real. Se uma chave foi exposta, revogue e crie outra em:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL_MAIN=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
# Opcional (config/services.php): OPENAI_API_URL — úteis após php artisan config:cache

# Governança de IA (config/ai.php) — ETAPA 13: otimização de custos/tokens
# PRODUÇÃO: copie estas variáveis para o .env do servidor e recarregue a config:
#   php artisan config:clear   (ou php artisan config:cache após validar)
# Valores recomendados pós-auditoria: classificador LLM desligado, histórico compacto.
AI_RESPONSE_CACHE_TTL=86400
AI_CHAT_HISTORY_MESSAGES=4
AI_LLM_CLASSIFIER_ENABLED=false
AI_QUEUE_ENABLED=false
# Limites USD (0 = desligado; em produção multi-clínica considere AI_DAILY_USD_LIMIT_CLINIC)
AI_DAILY_USD_LIMIT_GLOBAL=0
AI_DAILY_USD_LIMIT_CLINIC=0
AI_ERROR_RATE_ALERT_PERCENT=5

# Chat IA: limite diário de mensagens do utilizador (plano grátis). Premium ignora.
CHAT_FREE_DAILY_USER_MESSAGES=8

# Omnichannel: POST /omnichannel/webhook — header X-Omni-Secret deve coincidir com este valor.
# OBRIGATÓRIO em produção (APP_ENV=production); sem valor o endpoint retorna 503.
OMNI_WEBHOOK_SECRET=

# --- PDF oficial / multi-empresa (histórico, validação, filas) ---
# Disco Laravel onde ficam os PDFs emitidos (ex.: local, s3).
PDF_HISTORICO_DISK=local
# Subpasta dentro do disco (Storage::disk(...)).
PDF_HISTORICO_DIRECTORY=historico-pdfs
# Segmento público da URL de validação (sem / inicial), ex.: validar-documento
PDF_VALIDATION_PATH=validar-documento
# Dias até expirar validação no portal público (0 = sem expiração automática).
PDF_DEFAULT_TTL_DAYS=0

# --- WhatsApp (envio opcional de PDF; contrato depende do gateway) ---
WHATSAPP_DRIVER=none
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

# --- Google Social Login (Socialite) ---
# Obtenha em: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# --- Google Cloud Vision (OCR — importação de treino por foto) ---
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=

# --- Sistema de Backup ---
BACKUP_NOTIFICATION_EMAIL=admin@example.com
BACKUP_ARCHIVE_PASSWORD=
BACKUP_DISK=s3

# S3 Backup (Pode ser o mesmo AWS_ ou separado)
AWS_BACKUP_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID}"
AWS_BACKUP_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY}"
AWS_BACKUP_REGION="${AWS_DEFAULT_REGION}"
AWS_BACKUP_BUCKET=


# --- Monitoramento (opcional) ---
# Ver docs/MONITORAMENTO.md
UPTIME_MONITOR_URL="${APP_URL}/up"
HEALTH_MONITOR_URL="${APP_URL}/health"
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Observabilidade (logs, alertas, API audit) ---
API_ACCESS_LOG_ENABLED=true
API_ACCESS_LOG_SAMPLE_RATE=1.0
CLIENT_ERROR_LOG_ENABLED=true
CLIENT_ERROR_RATE_LIMIT=10
SLACK_OPS_WEBHOOK_URL=
WHATSAPP_OPS_ENABLED=false
WHATSAPP_OPS_API_URL=
OPS_ALERT_DEDUPE_MINUTES=30
OPS_DISK_WARNING_PERCENT=85
LOG_RETENTION_ERRORS_DAYS=15
LOG_RETENTION_AUTH_DAYS=90
LOG_RETENTION_API_DAYS=30
LOG_RETENTION_PULSE_DAYS=7

# Filas nomeadas (workers Supervisor / Horizon)
QUEUE_NAME_DEFAULT=default
QUEUE_NAME_PDF=pdf
QUEUE_NAME_AI=ai
QUEUE_NAME_WEBHOOKS=webhooks
OPS_FAILED_JOBS_HOUR_THRESHOLD=10
OPS_PENDING_JOBS_THRESHOLD=100

# Laravel Horizon (requer Redis + composer require laravel/horizon)
HORIZON_ENABLED=false
HORIZON_PATH=horizon

# API mobile (Sanctum v1)
API_TOKEN_EXPIRATION_DAYS=30

# Firebase Cloud Messaging (push notifications Android/iOS)
FCM_SERVER_KEY=

