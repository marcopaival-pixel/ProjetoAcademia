# =============================================================================
# ProjetoAcademia — Template de ambiente para PRODUÇÃO
# =============================================================================
# ATENÇÃO: Nunca versionar este ficheiro com valores reais.
# Copie para .env e preencha os valores reais no servidor de produção.
# =============================================================================

APP_NAME=ProjetoAcademia
APP_ENV=production
APP_KEY=                        # Gerar com: php artisan key:generate

# CRÍTICO: manter false em produção para não expor stack traces / dados
APP_DEBUG=false

APP_URL=https://seudominio.com
APP_PUBLIC_URL=https://seudominio.com
APP_BASE_PATH=
APP_TIMEZONE=America/Sao_Paulo

# E-mail do administrador padrão (seed inicial)
ADMIN_EMAIL=
# Alertas críticos quando a base de dados está indisponível
OPERATIONAL_ALERT_EMAIL=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# PRODUÇÃO: usar warning ou error (nunca debug — loga SQL e dados sensíveis)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Banco de Dados ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=projetoacademia
DB_USERNAME=                    # Nunca usar root em produção
DB_PASSWORD=                    # Senha forte (min 24 chars)

# --- Sessão ---
SESSION_DRIVER=redis            # Redis em produção (não database)
SESSION_COOKIE=projetoacademia_sid
SESSION_LIFETIME=120
# PRODUÇÃO: obrigatório — encripta o conteúdo do cookie de sessão
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.seudominio.com
# PRODUÇÃO (HTTPS): cookie de sessão só via TLS
SESSION_SECURE_COOKIE=true

# --- Cache e Filas (Redis em produção) ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis          # Redis evita gargalo no MySQL
CACHE_STORE=redis               # Redis para cache (não database)

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                 # Senha forte do Redis
REDIS_PORT=6379

# --- E-mail SMTP ---
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@seudominio.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_COPY_ADMIN=
MAIL_COPY_FINANCE=
MAIL_COPY_SUPPORT=
MAIL_COPY_BCC=
MAIL_DEDUPE_SECONDS=60

# Confirmação de e-mail
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_VERIFICATION_MAX_SENDS_PER_HOUR=3

# --- Mercado Pago ---
MP_ACCESS_TOKEN=                # Token de produção (nunca sandbox)
# OBRIGATÓRIO em produção: chave secreta do webhook MP (Conta > Webhooks)
# Sem este valor, qualquer actor pode forjar notificações de pagamento!
MP_WEBHOOK_SECRET=

# --- Open Food Facts ---
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org
OPENFOODFACTS_MAX_REQUESTS_PER_MINUTE=30
OPENFOODFACTS_CACHE_PRODUCT_TTL=3600
OPENFOODFACTS_CACHE_SEARCH_TTL=600

# --- OpenAI ---
OPENAI_API_KEY=                 # Nunca expor; revogar se vazar
OPENAI_MODEL_MAIN=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# Mensagens diárias do chat IA (plano gratuito)
CHAT_FREE_DAILY_USER_MESSAGES=8

# --- Google OAuth (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# --- Google Cloud Vision (OCR — importação de treino por foto) ---
GOOGLE_VISION_API_KEY=

# --- Omnichannel ---
# OBRIGATÓRIO em produção: sem este secret, o webhook omni é público
OMNI_WEBHOOK_SECRET=

# --- PDF ---
PDF_HISTORICO_DISK=local        # Trocar por s3 em prod com volumes
PDF_HISTORICO_DIRECTORY=historico-pdfs
PDF_VALIDATION_PATH=validar-documento
PDF_DEFAULT_TTL_DAYS=0

# --- WhatsApp ---
WHATSAPP_DRIVER=none
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

# --- AWS (se usar S3 para storage de PDFs) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Backup (Spatie) ---
BACKUP_NOTIFICATION_EMAIL=
BACKUP_ARCHIVE_PASSWORD=
BACKUP_DISK=s3
AWS_BACKUP_ACCESS_KEY_ID=
AWS_BACKUP_SECRET_ACCESS_KEY=
AWS_BACKUP_REGION=us-east-1
AWS_BACKUP_BUCKET=

# --- Monitoramento (opcional — ver docs/MONITORAMENTO.md) ---
UPTIME_MONITOR_URL="${APP_URL}/up"
HEALTH_MONITOR_URL="${APP_URL}/health"
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"
